generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  orderId      String   @id
  value        Float
  creationDate DateTime
  items        Item[]

  @@map("Order")
}

model Item {
  orderId   String
  productId Int
  quantity  Int
  price     Float
  order     Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@id([orderId, productId])
  @@index([orderId])
  @@map("Items")
}
